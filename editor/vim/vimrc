source $VIMRUNTIME/defaults.vim

let mapleader = " "
let maplocalleader = ","
let $VIMHOME = has('win32') ? expand('~/vimfiles') : expand('~/.vim')

" -------------------------------------------------- 
" Plugins
" --------------------------------------------------

if executable('git')
  let minpac_dir = $VIMHOME . '/pack/minpac/opt/minpac'

  if !isdirectory(minpac_dir)
    echo 'Bootstrapping minpac...'
    call mkdir(minpac_dir, 'p')
    call system('git clone --depth 1 https://github.com/k-takata/minpac.git '
      \ . shellescape(minpac_dir))
    if v:shell_error
      echohl ErrorMsg | echom 'Failed to clone minpac' | echohl None
    endif
  endif

  if isdirectory(minpac_dir)
    packadd minpac
    call minpac#init()

    call minpac#add('junegunn/fzf')
    call minpac#add('junegunn/fzf.vim')
    call minpac#add('iamcco/markdown-preview.nvim',
          \ {'do': 'packloadall! | call mkdp#util#install()'})
  endif
else
  echohl WarningMsg
  echom 'git not found on PATH; skipping plugin setup'
  echohl None
endif

function! s:HasPlugin(name) abort
  return !empty(globpath(&packpath, 'pack/*/start/' . a:name))
       \ || !empty(globpath(&packpath, 'pack/*/opt/' . a:name))
endfunction

" -------------------------------------------------- 
" Configs
" --------------------------------------------------

" Don't put .swp and other files in working dir, but in ~/.vim_aux
let vim_aux_dir = $VIMHOME . '/aux'
if !isdirectory(vim_aux_dir)
    call mkdir(vim_aux_dir, 'p')
endif
let &directory=vim_aux_dir
let &backupdir=vim_aux_dir
let &undodir=vim_aux_dir

set nu rnu
set autowrite
set textwidth=80
set shiftwidth=2
set expandtab
set tabstop=2
set autoindent
set showmatch

nnoremap <C-s> :w<CR>
nnoremap <C-q> :q<CR>
nnoremap <C-n> :tabnew<CR>
nnoremap <C-L> gt
nnoremap <C-H> gT
if s:HasPlugin('fzf.vim')
  nnoremap <C-p> :FZF<CR>
endif

" Reindent
function! ReindentSpaces(from, to) range
  let l:saved_et = &expandtab
  let l:saved_ts = &tabstop

  execute 'set tabstop=' . a:from . ' noexpandtab'
  execute a:firstline . ',' . a:lastline . 'retab!'
  execute 'set tabstop=' . a:to . ' expandtab'
  execute a:firstline . ',' . a:lastline . 'retab!'

  let &expandtab = l:saved_et
  let &tabstop = l:saved_ts
endfunction

command! -nargs=+ -range=% Reindent <line1>,<line2>call ReindentSpaces(<f-args>)

augroup TextWidthForProse
  " Whenever formatting with gq, avoid double spaces.
  autocmd!
  autocmd FileType text,markdown setlocal nojoinspaces
augroup END
